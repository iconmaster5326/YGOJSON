  "text": {
    "en": {
      "name": "Artmegia Finemelt",
      "effect": "Your opponent cannot target Level 6 or lower \"Artmegia\" monsters you control with card effects. You can only use each of the following effects of \"Artmegia Finemelt\" once per turn. If you control an \"Artmegia\" card: You can Special Summon this card from your hand, then you can draw 1 card. During the Main Phase, if you control 3 or more different Monster Types (Quick Effect): You can negate the effects of all face-up monsters your opponent currently controls, also their current ATK become halved until the end of this turn.",
      "official": false
    },
    "ja": {
