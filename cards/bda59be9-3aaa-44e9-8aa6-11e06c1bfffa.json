  "text": {
    "en": {
      "name": "Elemental HERO Neos",
      "effect": "A new Elemental HERO has arrived from Neo-Space! When he initiates a Contact Fusion with a Neo-Spacian his unknown powers are unleashed."
    },
    "fr": {
      "name": "N\u00e9os, H\u00c9ROS \u00c9l\u00e9mentaire",
      "effect": "Un nouveau H\u00c9ROS \u00c9l\u00e9mentaire a \u00e9merg\u00e9 du N\u00e9o-Space ! Lorsqu'il a engag\u00e9 un Contact Fusion avec un N\u00e9o-Spacien, ses pouvoirs cach\u00e9s se sont r\u00e9v\u00e9l\u00e9s."
    },
    "de": {
      "name": "Elementar-HELD Neos",
      "effect": "Ein neuer Elementar-HELD ist aus dem Neo-Weltraum eingetroffen! Wenn er eine Kontaktfusion mit einem Neo-Weltraumbewohner ausl\u00f6st, werden seine unbekannten Kr\u00e4fte entfesselt."
    },
    "it": {
