    "en": {
      "name": "Kurikulink @Ignister",
      "effect": "(Quick Effect): You can Tribute 1 \"@Ignister\" monster; Special Summon this card from your hand or GY, but banish it when it leaves the field. When a card or effect is activated that targets a Cyberse monster(s) you control and you control a Cyberse monster Special Summoned from the Extra Deck (Quick Effect): You can Tribute this card; negate that effect. You can only use each effect of \"Kurikulink @Ignister\" once per turn.",
      "official": false
    },
    "ja": {
