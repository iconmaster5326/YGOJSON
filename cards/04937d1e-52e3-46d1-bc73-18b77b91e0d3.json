    },
    "ko": {
      "name": "\uac00\ub514\uc5b8 \ucf00\uc774\uc2a4\ud2b8",
      "effect": "\"\uc815\uc801\uc758 \ub85c\ub4dc - \ucf00\uc774\uc2a4\ud2b8\"\uac00 \uc790\uc2e0\uc758 \ud544\ub4dc \uc704\uc5d0 \uc874\uc7ac\ud560 \ub54c\ub9cc, \uc774 \uce74\ub4dc\ub294 \uc77c\ubc18 \uc18c\ud658 / \ubc18\uc804 \uc18c\ud658 / \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4. \uc774 \uce74\ub4dc\ub294 \ub9c8\ubc95\uc758 \ud6a8\uacfc\ub97c \ubc1b\uc9c0 \uc54a\ub294\ub2e4. \ub610\ud55c, \uc0c1\ub300 \ubaac\uc2a4\ud130\ub85c\ubd80\ud130 \uacf5\uaca9 \ub300\uc0c1\uc774 \ub418\uc9c0 \uc54a\ub294\ub2e4."
