  "text": {
    "en": {
      "name": "Eternal Sunshine",
      "effect": "Monsters you control gain 500 DEF for each \"Ancient Fairy Dragon\", and monster that mentions it, that you control. Once per Chain: You can target 1 face-up monster your opponent controls; until the end of this turn, its current ATK/DEF become halved, also its effects are negated. You can use this effect of \"Eternal Sunshine\" a number of times per turn up to the number of \"Ancient Fairy Dragon\", and monsters that mention it, that you control.",
      "official": false
    },
    "ja": {
