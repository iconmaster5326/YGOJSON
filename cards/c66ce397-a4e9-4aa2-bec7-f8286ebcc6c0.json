  "text": {
    "en": {
      "name": "Ryu-Ge Ruin",
      "effect": "Your opponent cannot target \"Ryu-Ge\" monsters you control with card effects. You can only use each of the following effects of \"Ryu-Ge Ruin\" once per turn. If you have a \"Ryu-Ge\" Pendulum Monster in your field or face-up Extra Deck: You can shuffle 2 \"Ryu-Ge\" monsters from your hand, GY, and/or banishment into the Deck, then target 1 monster on the field; destroy it. If this card is destroyed: You can Set 1 non-Continuous \"Ryu-Ge\" Trap from your Deck, GY, or banishment.",
      "official": false
    },
    "ja": {
