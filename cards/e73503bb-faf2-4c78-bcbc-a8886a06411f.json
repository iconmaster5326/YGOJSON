    },
    "de": {
      "name": "Chthonian Soldat",
      "effect": "Wenn diese Karte als Ergebnis eines Kampfes mit einem angreifenden Monster deines Gegners zerst\u00f6rt und auf den Friedhof gelegt wird, f\u00fcge den Kampfschaden, den du erhalten hast, auch den Life Points deines Gegners zu."
    },
    "es": {
      "name": "Soldado del Infierno",
      "effect": "Cuando esta carta es destruida por un monstruo atacante de tu adversario y mandada al Cementerio, inflige el da\u00f1o de batalla que recibiste a los Life Points de tu adversario tambi\u00e9n."
    },
    "fr": {
      "name": "Soldat Chthonien",
      "effect": "Lorsque cette carte est d\u00e9truite par un monstre attaquant de votre adversaire et envoy\u00e9e au Cimeti\u00e8re, infligez les dommages de combat que vous avez re\u00e7u durant ce combat \u00e9galement aux Life Points de votre adversaire."
    },
    "it": {
      "name": "Soldato Chthoniano",
      "effect": "Quando questa carta viene distrutta da un mostro attaccante del tuo avversario e mandata al Cimitero, infliggi il danno da combattimento ricevuto in questa battaglia anche ai Life Points del tuo avversario."
    },
    "pt": {
      "name": "Soldado Ctoniano",
      "effect": "Quando este card for destru\u00eddo pelo monstro atacante do oponente e enviado ao Cemit\u00e9rio, o Dano de Batalha que voc\u00ea sofreu nesta batalha tamb\u00e9m ser\u00e1 causado ao oponente."
    },
    "ja": {
