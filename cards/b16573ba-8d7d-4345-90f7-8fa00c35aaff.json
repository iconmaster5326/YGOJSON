    "ja": {
      "name": "\u7121\u9650\u7adc\u30b7\u30e5\u30f4\u30a1\u30eb\u30c4\u30b7\u30eb\u30c8",
      "effect": "\u3053\u306e\u30ab\u30fc\u30c9\u540d\u306e\u52b9\u679c\u306f\uff11\u30bf\u30fc\u30f3\u306b\uff11\u5ea6\u3057\u304b\u4f7f\u7528\u3067\u304d\u305a\u3001\u3053\u306e\u52b9\u679c\u3092\u767a\u52d5\u3059\u308b\u30bf\u30fc\u30f3\u3001\u81ea\u5206\u306f\u30c9\u30e9\u30b4\u30f3\u65cf\uff38\u30e2\u30f3\u30b9\u30bf\u30fc\u3057\u304b\uff25\uff38\u30c7\u30c3\u30ad\u304b\u3089\u7279\u6b8a\u53ec\u559a\u3067\u304d\u306a\u3044\u3002\u2460\uff1a\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u5b58\u5728\u3057\u306a\u3044\u5834\u5408\u3001\u307e\u305f\u306f\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u653b\u6483\u529b\uff12\uff10\uff10\uff10\u4ee5\u4e0a\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u5b58\u5728\u3059\u308b\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002\u3053\u306e\u30ab\u30fc\u30c9\u3092\u624b\u672d\u304b\u3089\u7279\u6b8a\u53ec\u559a\u3057\u3001\u30c7\u30c3\u30ad\u304b\u3089\u300c\u7121\u9650\u7adc\u30b7\u30e5\u30f4\u30a1\u30eb\u30c4\u30b7\u30eb\u30c8\u300d\u4ee5\u5916\u306e\u5149\u30fb\u95c7\u5c5e\u6027\u306e\u30c9\u30e9\u30b4\u30f3\u65cf\u30fb\u30ec\u30d9\u30eb\uff18\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u5b88\u5099\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3059\u308b\u3002\u3053\u306e\u52b9\u679c\u3067\u30c7\u30c3\u30ad\u304b\u3089\u7279\u6b8a\u53ec\u559a\u3057\u305f\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u52b9\u679c\u306f\u7121\u52b9\u5316\u3055\u308c\u308b\u3002"
    },
    "zh-CN": {
      "name": "\u65e0\u9650\u9f99 \u53f2\u74e6\u897f",
      "effect": "\u6b64\u5361\u540d\u7684\u6548\u679c\uff11\u56de\u5408\u4ec5\u53ef\u4f7f\u7528\uff11\u6b21\uff0c\u53d1\u52a8\u6b64\u6548\u679c\u7684\u56de\u5408\u4e2d\uff0c\u81ea\u5df1\u4ece\u989d\u5916\u724c\u7ec4\u4ec5\u53ef\u7279\u6b8a\u53ec\u5524\u9f99\u65cf\u8d85\u91cf\u602a\u517d\u3002\u2460\uff1a\u81ea\u5df1\u573a\u4e0a\u4e0d\u5b58\u5728\u602a\u517d\u7684\u60c5\u51b5\u4e0b\uff0c\u6216\u5bf9\u624b\u573a\u4e0a\u5b58\u5728\u653b\u51fb\u529b\uff12\uff10\uff10\uff10\u4ee5\u4e0a\u7684\u602a\u517d\u7684\u60c5\u51b5\u4e0b\u53ef\u4ee5\u53d1\u52a8\u3002\u4ece\u624b\u724c\u5c06\u6b64\u5361\u7279\u6b8a\u53ec\u5524\uff0c\u4ece\u724c\u7ec4\u5c06\u201c\u65e0\u9650\u9f99 \u53f2\u74e6\u897f\u201d\u4ee5\u5916\u7684\uff11\u53ea\u5149\u30fb\u6697\u5c5e\u6027\u7684\u9f99\u65cf\u30fb\u7b49\u7ea7\uff18\u602a\u517d\u4ee5\u5b88\u5907\u8868\u793a\u7279\u6b8a\u53ec\u5524\u3002\u4ee5\u6b64\u6548\u679c\u4ece\u724c\u7ec4\u7279\u6b8a\u53ec\u5524\u7684\u602a\u517d\u7684\u6548\u679c\u65e0\u6548\u5316\u3002"
    },
    "ko": {
      "name": "\ubb34\ud55c\ub8e1 \uc288\ubc1c\uce20\uc2e4\ud2b8",
      "effect": "\uc774 \uce74\ub4dc\uba85\uc758 \ud6a8\uacfc\ub294 1\ud134\uc5d0 1\ubc88\ubc16\uc5d0 \uc0ac\uc6a9\ud560 \uc218 \uc5c6\uc73c\uba70, \uc774 \ud6a8\uacfc\ub97c \ubc1c\ub3d9\ud558\ub294 \ud134\uc5d0, \uc790\uc2e0\uc740 \ub4dc\ub798\uace4\uc871 \uc5d1\uc2dc\uc988 \ubaac\uc2a4\ud130\ubc16\uc5d0 \uc5d1\uc2a4\ud2b8\ub77c \ub371\uc5d0\uc11c \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc5c6\ub2e4. \u2460: \uc790\uc2e0 \ud544\ub4dc\uc5d0 \ubaac\uc2a4\ud130\uac00 \uc874\uc7ac\ud558\uc9c0 \uc54a\uc744 \uacbd\uc6b0, \ub610\ub294 \uc0c1\ub300 \ud544\ub4dc\uc5d0 \uacf5\uaca9\ub825 2000 \uc774\uc0c1\uc758 \ubaac\uc2a4\ud130\uac00 \uc874\uc7ac\ud560 \uacbd\uc6b0\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uc774 \uce74\ub4dc\ub97c \ud328\uc5d0\uc11c \ud2b9\uc218 \uc18c\ud658\ud558\uace0, \ub371\uc5d0\uc11c \"\ubb34\ud55c\ub8e1 \uc288\ubc1c\uce20\uc2e4\ud2b8\" \uc774\uc678\uc758 \ube5b / \uc5b4\ub460 \uc18d\uc131\uc778 \ub4dc\ub798\uace4\uc871 / \ub808\ubca8 8 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \uc218\ube44 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud55c\ub2e4. \uc774 \ud6a8\uacfc\ub85c \ub371\uc5d0\uc11c \ud2b9\uc218 \uc18c\ud658\ud55c \ubaac\uc2a4\ud130\uc758 \ud6a8\uacfc\ub294 \ubb34\ud6a8\ud654\ub41c\ub2e4."
    }
