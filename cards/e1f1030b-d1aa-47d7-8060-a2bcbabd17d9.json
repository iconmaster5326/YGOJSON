    "ko": {
      "name": "\uc232\uc758 \ucca9\uc790 \ubc30\ud2b8",
      "effect": "\uc774 \uce74\ub4dc\uba85\uc758, \u2460\uc758 \ubc29\ubc95\uc5d0 \uc758\ud55c \ud2b9\uc218 \uc18c\ud658\uc740 1\ud134\uc5d0 1\ubc88\ubc16\uc5d0 \ud560 \uc218 \uc5c6\uc73c\uba70, \u2461\uc758 \ud6a8\uacfc\ub294 1\ud134\uc5d0 1\ubc88\ubc16\uc5d0 \uc0ac\uc6a9\ud560 \uc218 \uc5c6\ub2e4. \u2460: \ud544\ub4dc \uc874\uc5d0 \uc55e\uba74 \ud45c\uc2dc \uce74\ub4dc\uac00 \uc874\uc7ac\ud560 \uacbd\uc6b0, \uc774 \uce74\ub4dc\ub294 \ud328\uc5d0\uc11c \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4. \u2461: \uc774 \uce74\ub4dc\ub97c \uc77c\ubc18 \uc18c\ud658 / \ud2b9\uc218 \uc18c\ud658\ud588\uc744 \uacbd\uc6b0, \uc790\uc2e0\uc758 \ud544\ub4dc\ub098 \ubb18\uc9c0\uc5d0 \"Fairy Tale(\ud398\uc5b4\ub9ac\ud14c\uc77c) \uc11c\uc7a5 \uc5ec\uc815\uc758 \uc0c8\ubcbd\ube5b\"\uc774 \uc874\uc7ac\ud558\uace0 \uc788\uc73c\uba74 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \ub371\uc5d0\uc11c \uc57c\uc218\uc871 / \ube5b \uc18d\uc131 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ud328\uc5d0 \ub123\ub294\ub2e4."
