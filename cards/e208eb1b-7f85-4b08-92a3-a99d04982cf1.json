  "text": {
    "en": {
      "name": "Artmegia Banish - Change",
      "effect": "Place 1 \"Artmegia the Academy City of Divine Arts\" from your Deck or GY face-up in your Field Zone, or, if you control \"Artmegia the Academy City of Divine Arts\", you can add 1 \"Artmegia\" card from your Deck to your hand instead, except \"Artmegia Banish - Change\". When your \"Artmegia\" monster is targeted for an attack: You can banish this card from your GY; negate that attack, then you can Special Summon 1 \"Medius the Innocent\" from your hand. You can only use each effect of \"Artmegia Banish - Change\" once per turn.",
      "official": false
    },
    "ja": {
