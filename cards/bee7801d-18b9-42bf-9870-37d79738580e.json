    "ja": {
      "name": "\u30e2\u30fc\u30bf\u30fc\u30fb\u30ab\u30a4\u30b6\u30eb",
      "effect": "\u3053\u306e\u30ab\u30fc\u30c9\u540d\u306e\u2460\u2461\u306e\u52b9\u679c\u306f\u305d\u308c\u305e\u308c\uff11\u30bf\u30fc\u30f3\u306b\uff11\u5ea6\u3057\u304b\u4f7f\u7528\u3067\u304d\u306a\u3044\u3002\u2460\uff1a\u624b\u672d\u306e\u3053\u306e\u30ab\u30fc\u30c9\u3092\u76f8\u624b\u306b\u898b\u305b\u3066\u767a\u52d5\u3067\u304d\u308b\u3002\u6a5f\u68b0\u65cf\u30fb\u95c7\u5c5e\u6027\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u306e\u53ec\u559a\u3092\u884c\u3046\u3002\u2461\uff1a\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u5bfe\u8c61\u3068\u3057\u3066\u767a\u52d5\u3067\u304d\u308b\u3002\u305d\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u7834\u58ca\u3059\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u300c\u30e2\u30fc\u30bf\u30fc\u30c8\u30fc\u30af\u30f3\u300d\uff08\u6a5f\u68b0\u65cf\u30fb\u5730\u30fb\u661f\uff11\u30fb\u653b\uff0f\u5b88\uff12\uff10\uff10\uff09\uff11\u4f53\u3092\u653b\u6483\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3067\u304d\u308b\u3002"
    },
    "ko": {
      "name": "\ubaa8\ud130 \uce74\uc774\uc790\ub974",
      "effect": "\uc774 \uce74\ub4dc\uba85\uc758 \u2460\u2461\uc758 \ud6a8\uacfc\ub294 \uac01\uac01 1\ud134\uc5d0 1\ubc88\ubc16\uc5d0 \uc0ac\uc6a9\ud560 \uc218 \uc5c6\ub2e4. \u2460: \ud328\uc758 \uc774 \uce74\ub4dc\ub97c \uc0c1\ub300\uc5d0\uac8c \ubcf4\uc5ec\uc8fc\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uae30\uacc4\uc871 / \uc5b4\ub460 \uc18d\uc131 \ubaac\uc2a4\ud130 1\uc7a5\uc758 \uc77c\ubc18 \uc18c\ud658\uc744 \uc2e4\ud589\ud55c\ub2e4. \u2461: \uc790\uc2e0 \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uadf8 \ubaac\uc2a4\ud130\ub97c \ud30c\uad34\ud55c\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0 \ud544\ub4dc\uc5d0 \"\ubaa8\ud130 \ud1a0\ud070\"(\uae30\uacc4\uc871 / \ub545 / \ub808\ubca8 1 / \uacf5 200 / \uc218 200) 1\uc7a5\uc744 \uacf5\uaca9 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4."
    },
    "zh-CN": {
      "name": "\u9a6c\u8fbe\u51ef\u6492",
      "effect": "\u6b64\u5361\u540d\u7684\u2460\u2461\u6548\u679c1\u56de\u5408\u4ec5\u53ef\u5404\u4f7f\u75281\u6b21\u3002\u2460\uff1a\u5411\u5bf9\u624b\u51fa\u793a\u624b\u724c\u7684\u6b64\u5361\u53ef\u4ee5\u53d1\u52a8\u3002\u8fdb\u884c1\u53ea\u673a\u68b0\u65cf\u30fb\u6697\u5c5e\u6027\u602a\u517d\u7684\u53ec\u5524\u3002\u2461\uff1a\u4ee5\u81ea\u5df1\u573a\u4e0a\u76841\u53ea\u602a\u517d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u8be5\u602a\u517d\u7834\u574f\u3002\u7136\u540e\uff0c\u53ef\u5c061\u53ea\u201c\u9a6c\u8fbe\u884d\u751f\u7269\u201d\uff08\u673a\u68b0\u65cf\u30fb\u5730\u30fb\u661f1\u30fb\u653b/\u5b88200\uff09\u4ee5\u653b\u51fb\u8868\u793a\u7279\u6b8a\u53ec\u5524\u81f3\u81ea\u5df1\u573a\u4e0a\u3002"
