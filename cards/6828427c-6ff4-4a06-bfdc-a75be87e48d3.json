  "text": {
    "en": {
      "name": "Angelcaido of the Golden Land",
      "effect": "\"Eldlich the Golden Lord\" + 1 Zombie monster\nMust be either Fusion Summoned, or Special Summoned (from your Extra Deck) by Tributing 1 LIGHT Zombie monster while you have \"Eldlich the Golden Lord\" on your field or in your GY. You can only Special Summon \"Angelcaido of the Golden Land\" once per turn either of these ways. If this card is sent from the field to the GY: You can Special Summon 1 \"Eldlich\" monster from your Deck, Extra Deck, or GY. You can only use this effect of \"Angelcaido of the Golden Land\" once per turn.",
      "official": false
    },
    "ja": {
      "name": "\u9ec4\u91d1\u90f7\u306e\u30a2\u30f3\u30d8\u30eb\u30ab\u30a4\u30c9",
