  "id": "ed8e74ca-1c43-4e82-9213-cc3cdca94320",
  "text": {
    "en": {
      "name": "Super Polymerization",
      "effect": "Discard 1 card; Fusion Summon 1 Fusion Monster from your Extra Deck, using monsters from either field as Fusion Material. Neither player can activate cards or effects in response to this card's activation."
    },
    "de": {
      "name": "Superpolymerisation",
      "effect": "Wirf 1 Karte ab; beschw\u00f6re 1 Fusionsmonster als Fusionsbeschw\u00f6rung von deinem Extra Deck und verwende daf\u00fcr Monster von einer beliebigen Spielfeldseite als Fusionsmaterial. Kein Spieler kann Karten oder Effekte als Reaktion auf die Aktivierung dieser Karte aktivieren."
    },
    "es": {
      "name": "S\u00faper Polimerizaci\u00f3n",
      "effect": "Descarta 1 carta; Invoca por Fusi\u00f3n 1 Monstruo de Fusi\u00f3n desde tu Deck Extra, usando monstruos de cualquier Campo como Material de Fusi\u00f3n. Ning\u00fan jugador puede activar cartas o efectos en respuesta a la activaci\u00f3n de esta carta."
    },
    "fr": {
      "name": "Super Polym\u00e9risation",
      "effect": "D\u00e9faussez 1 carte ; Invoquez par Fusion 1 Monstre Fusion depuis votre Extra Deck, en utilisant des monstres depuis au moins l'un des Terrains comme Mat\u00e9riel Fusion. Aucun joueur ne peut activer ni de cartes ni d'effets en r\u00e9ponse \u00e0 l'activation de cette carte."
    },
    "it": {
      "name": "Super Polimerizzazione",
      "effect": "Scarta 1 carta; Evoca tramite Fusione 1 Mostro Fusione dal tuo Extra Deck, utilizzando mostri da qualsiasi Terreno come Materiale da Fusione. Nessun giocatore pu\u00f2 attivare carte o effetti in risposta all'attivazione di questa carta."
    },
    "pt": {
      "name": "Super Polimeriza\u00e7\u00e3o",
      "effect": "Descarte 1 card; Invoque por Invoca\u00e7\u00e3o-Fus\u00e3o 1 Monstro de Fus\u00e3o do seu Deck Adicional, usando monstros de qualquer campo como Mat\u00e9ria de Fus\u00e3o. Nenhum duelista pode ativar cards ou efeitos em resposta \u00e0 ativa\u00e7\u00e3o deste card."
    },
    "ja": {
      "name": "\u8d85\u878d\u5408",
      "effect": "\u3053\u306e\u30ab\u30fc\u30c9\u306e\u767a\u52d5\u306b\u5bfe\u3057\u3066\u9b54\u6cd5\u30fb\u7f60\u30fb\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u52b9\u679c\u306f\u767a\u52d5\u3067\u304d\u306a\u3044\u3002\u2460\uff1a\u624b\u672d\u3092\uff11\u679a\u6368\u3066\u3066\u767a\u52d5\u3067\u304d\u308b\u3002\u81ea\u5206\u30fb\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u878d\u5408\u7d20\u6750\u3068\u3057\u3001\u878d\u5408\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u878d\u5408\u53ec\u559a\u3059\u308b\u3002"
    },
    "ko": {
      "name": "\ucd08\uc735\ud569",
      "effect": "\uc774 \uce74\ub4dc\uc758 \ubc1c\ub3d9\uc5d0 \ub300\ud558\uc5ec \ub9c8\ubc95 / \ud568\uc815 / \ubaac\uc2a4\ud130\uc758 \ud6a8\uacfc\ub294 \ubc1c\ub3d9\ud560 \uc218 \uc5c6\ub2e4. \u2460: \ud328\ub97c 1\uc7a5 \ubc84\ub9ac\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uc790\uc2e0 / \uc0c1\ub300 \ud544\ub4dc\uc5d0\uc11c, \uc735\ud569 \ubaac\uc2a4\ud130 \uce74\ub4dc\uc5d0 \uae30\uc7ac\ub41c \uc735\ud569 \uc18c\uc7ac \ubaac\uc2a4\ud130\ub97c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0, \uadf8 \uc735\ud569 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \uc5d1\uc2a4\ud2b8\ub77c \ub371\uc5d0\uc11c \uc735\ud569 \uc18c\ud658\ud55c\ub2e4."
    },
    "zh-TW": {
