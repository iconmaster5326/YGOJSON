    },
    "de": {
      "name": "Linke Hand des Magiers",
      "effect": "Annulliere den Effekt der ersten Fallenkarte oder des ersten Falleneffekts deines Gegners, die oder der in jedem Spielzug aufgel\u00f6st wird, solange du ein Hexer-Monster kontrollierst, und falls du dies tust, zerst\u00f6re die Karte."
    },
    "es": {
      "name": "Mano Izquierda del Mago",
      "effect": "Mientras controles un monstruo Lanzador de Conjuros, niega el efecto de la primera Carta de Trampa o efecto de Trampa de tu adversario que se resuelva cada turno y, si lo haces, destruye esa carta."
    },
    "fr": {
      "name": "Main Gauche du Magicien",
      "effect": "Annulez l'effet de la premi\u00e8re Carte Pi\u00e8ge ou effet de Pi\u00e8ge de votre adversaire qui est r\u00e9solu chaque tour tant que vous contr\u00f4lez un monstre Magicien, et si vous le faites, d\u00e9truisez la carte."
    },
    "it": {
      "name": "Mano Sinistra del Mago",
      "effect": "Annulla l'effetto della prima Carta Trappola o suo effetto del tuo avversario che si risolve ogni turno mentre controlli un mostro Incantatore e, se lo fai, distruggi quella carta."
    },
    "pt": {
      "name": "M\u00e3o Esquerda do Mago",
      "effect": "Negue o efeito do primeiro Card ou efeito de Armadilha do seu oponente que resolver a cada turno enquanto voc\u00ea controlar um monstro Mago e, se isso acontecer, destrua esse card."
    },
