    },
    "ko": {
      "name": "\ub9c8\uad49\uc2e0 \uac08\ubc14\uc2a4",
      "effect": "\ud328\uc5d0\uc11c 1\uc7a5 \ubb18\uc9c0\uc5d0 \ubc84\ub9ac\uace0 \ubc1c\ub3d9\ud55c\ub2e4. \uc774 \uce74\ub4dc\uc758 \uacf5\uaca9\ub825 \uc774\ud558\uc758 \uc218\ube44\ub825\uc744 \uac00\uc9c4, \uc0c1\ub300 \ud544\ub4dc \uc704\uc5d0 \uc55e\uba74 \ud45c\uc2dc\ub85c \uc874\uc7ac\ud558\ub294 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ud30c\uad34\ud55c\ub2e4."
    },
    "zh-TW": {
