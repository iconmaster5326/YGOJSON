  "text": {
    "en": {
      "name": "Trickstar Noble Angel",
      "effect": "2 \"Trickstar\" monsters\nIf this card is Link Summoned: You can add 1 \"Blue Tears\" card from your Deck to your hand. If you have a Fusion Monster on your field or in your GY: You can target 1 \"Trickstar\" monster in your GY; Special Summon it. If effect damage is inflicted (except during the Damage Step): You can target 1 face-up card on the field; destroy it. You can only use each effect of \"Trickstar Noble Angel\" once per turn.",
      "official": false
    },
    "ja": {
      "name": "\u30c8\u30ea\u30c3\u30af\u30b9\u30bf\u30fc\u30fb\u30ce\u30fc\u30d6\u30eb\u30a8\u30f3\u30b8\u30a7\u30eb",
