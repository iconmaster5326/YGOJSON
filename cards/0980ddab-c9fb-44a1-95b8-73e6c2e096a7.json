    "zh-CN": {
      "name": "\u4e34\u65f6\u6536\u5165",
      "effect": "\u2460\uff1a\u53ea\u8981\u8fd9\u5f20\u5361\u5728\u9b54\u6cd5\u4e0e\u9677\u9631\u533a\u57df\u5b58\u5728\uff0c\u6bcf\u6b21\u81ea\u5df1\u7684\u989d\u5916\u5361\u7ec4\u6709\u5361\u52a0\u5165\uff0c\u7ed9\u8fd9\u5f20\u5361\u653e\u7f6e1\u4e2a\u9b54\u529b\u6307\u793a\u7269\uff08\u6700\u591a3\u4e2a\uff09\u3002\u2461\uff1a\u628a\u67093\u4e2a\u9b54\u529b\u6307\u793a\u7269\u653e\u7f6e\u7684\u8fd9\u5f20\u5361\u9001\u53bb\u5893\u5730\u624d\u80fd\u53d1\u52a8\u3002\u81ea\u5df1\u4ece\u5361\u7ec4\u62bd2\u5f20\u3002"
