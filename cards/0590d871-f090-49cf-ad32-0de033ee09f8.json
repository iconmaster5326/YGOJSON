  "text": {
    "en": {
      "name": "Cunning of the Six Samurai",
      "effect": "Send 1 face-up \"Six Samurai\" monster you control to the Graveyard, then target 1 \"Six Samurai\" monster in either player's Graveyard; Special Summon that target."
    },
    "de": {
      "name": "Gerissenheit der Sechs Samurai",
      "effect": "Lege 1 offenes \u201eSechs Samurai\u201c-Monster, das du kontrollierst, auf den Friedhof und w\u00e4hle dann 1 \u201eSechs Samurai\u201c-Monster im Friedhof eines beliebigen Spielers; beschw\u00f6re das gew\u00e4hlte Ziel als Spezialbeschw\u00f6rung."
    },
    "es": {
      "name": "Astucia de los Seis Samur\u00e1is",
      "effect": "Manda al Cementerio 1 monstruo \"Seis Samur\u00e1is\" boca arriba que controles, y despu\u00e9s selecciona 1 monstruo \"Seis Samur\u00e1is\" en el Cementerio de cualquier jugador; Invoca ese objetivo de Modo Especial."
    },
    "fr": {
      "name": "Ruse des Six Samoura\u00efs",
      "effect": "Envoyez 1 monstre \"Six Samoura\u00efs\" face recto que vous contr\u00f4lez au Cimeti\u00e8re, puis ciblez 1 monstre \"Six Samoura\u00efs\" dans l'un des Cimeti\u00e8res ; Invoquez Sp\u00e9cialement la cible."
    },
    "it": {
      "name": "Astuzia dei Sei Samurai",
      "effect": "Manda 1 mostro \"Sei Samurai\" scoperto che controlli al Cimitero, poi scegli come bersaglio 1 mostro \"Sei Samurai\" nel Cimitero di qualsiasi giocatore; Evoca Specialmente quel bersaglio."
    },
    "pt": {
      "name": "Ast\u00facia dos Seis Samurai",
      "effect": "Envie 1 monstro \"Seis Samurai\" com a face para cima que voc\u00ea controla para o Cemit\u00e9rio e, depois, escolha 1 monstro \"Seis Samurai\" no Cemit\u00e9rio de qualquer duelista; Invoque o alvo por Invoca\u00e7\u00e3o-Especial."
    },
