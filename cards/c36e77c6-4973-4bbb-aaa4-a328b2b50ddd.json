      "effect": "\u6b64\u5361\u540d\u5728\u89c4\u5219\u4e0a\u4e5f\u89c6\u4e3a\u201c\u7f6a\u5b9d\u201d\u5361\u3002\u6b64\u5361\u540d\u7684\u2460\u2461\u6548\u679c1\u56de\u5408\u4ec5\u53ef\u5404\u4f7f\u75281\u6b21\u3002\u2460\uff1a\u4ece\u81ea\u5df1\u624b\u724c\u30fb\u5893\u5730\u5c06\u9b54\u6cd5\u5361\u548c\u9677\u9631\u5361\u54041\u5f20\u9664\u5916\u53ef\u4ee5\u53d1\u52a8\u3002\u4ece\u624b\u724c\u30fb\u5893\u5730\u5c06\u6b64\u5361\u7279\u6b8a\u53ec\u5524\u3002\u2461\uff1a\u5728\u81ea\u5df1\u30fb\u5bf9\u624b\u56de\u5408\u4e2d\uff0c\u652f\u4ed8\u4e00\u534aLP\uff0c\u4ee5\u5bf9\u624b\u573a\u4e0a\u76841\u5f20\u5361\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u8be5\u5361\u7834\u574f\u3002\u7136\u540e\uff0c\u573a\u4e0a\u5b58\u5728\u5176\u4ed6\u7684\u201c\u8fea\u4e9a\u8d1d\u5c14\u201d\u602a\u517d\u5361\u7684\u60c5\u51b5\u4e0b\uff0c\u53ef\u4ece\u989d\u5916\u724c\u7ec4\u5c061\u53ea\u5e7b\u60f3\u9b54\u65cf\u30fb\u9b54\u6cd5\u5e08\u65cf\u540c\u6b65\u602a\u517d\u7684\u534f\u8c03\u7279\u6b8a\u53ec\u5524\u3002"
