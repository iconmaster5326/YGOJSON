  "text": {
    "en": {
      "name": "Artmegia Messena - Awakening",
      "effect": "Special Summon 1 \"Artmegia\" monster or \"Medius the Innocent\" from your Deck, also, this turn, the activation of your cards and effects that include an effect that Fusion Summons a Fusion Monster cannot be negated, also your opponent cannot activate cards or effects when a monster is Fusion Summoned this way. You can banish this card from your GY, then target 1 \"Artmegia\" monster you control; return it to the hand/Extra Deck, and if you do, destroy 1 card your opponent controls. You can only use 1 \"Artmegia Messena - Awakening\" effect per turn, and only once that turn.",
      "official": false
    },
    "ja": {
      "name": "\u30a2\u30eb\u30c8\u30e1\u30ae\u30a2\u30fb\u30e1\u30bb\u30ca\uff0d\u899a\u9192\uff0d",
