    "zh-CN": {
      "name": "\u81ea\u9e23\u5929\u7434\u30fb\u4f3d\u62c9\u5fd2\u4e9ai",
      "effect": "\u201c\u81ea\u9e23\u5929\u7434\u201d\u602a\u517d\u6216\u201c\u661f\u9057\u7269\u201d\u602a\u517d1\u53ea\n\u81ea\u5df11\u56de\u5408\u4ec5\u53ef\u8fde\u63a5\u53ec\u55241\u6b21\u201c\u81ea\u9e23\u5929\u7434\u30fb\u4f3d\u62c9\u5fd2\u4e9ai\u201d\u3002\u6b64\u5361\u4e0d\u53ef\u4f5c\u4e3a\u8d85\u91cf\u53ec\u5524\u7684\u7d20\u6750\u3002\u6b64\u5361\u540d\u7684\u2460\u2461\u6548\u679c1\u56de\u5408\u4ec5\u53ef\u5404\u4f7f\u75281\u6b21\u3002\u2460\uff1a\u5c061\u5f20\u624b\u724c\u9001\u81f3\u5893\u5730\u53ef\u4ee5\u53d1\u52a8\u3002\u4ece\u81ea\u5df1\u724c\u7ec4\u30fb\u5893\u5730\u5c061\u53ea\u201c\u661f\u9057\u7269\u201d\u602a\u517d\u62161\u5f20\u201c\u81ea\u9e23\u5929\u7434\u30fb\u5df4\u522b\u5854\u201d\u52a0\u5165\u624b\u724c\u3002\u2461\uff1a\u6b64\u5361\u5b58\u5728\u4e8e\u5893\u5730\u7684\u60c5\u51b5\u4e0b\uff0c\u4ece\u81ea\u5df1\u5893\u5730\u5c061\u5f20\u5176\u4ed6\u201c\u81ea\u9e23\u5929\u7434\u201d\u5361\u9664\u5916\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u6b64\u5361\u7279\u6b8a\u53ec\u5524\u3002"
