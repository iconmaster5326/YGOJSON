  "text": {
    "en": {
      "name": "Royal Oppression",
      "official": false
    },
    "de": {
      "name": "Unterdr\u00fcckungsherrschaft",
      "effect": "Jeder Spieler kann 800 Life Points zahlen, um die Spezialbeschw\u00f6rung von Monstern und/oder einem Effekt, der Monster als Spezialbeschw\u00f6rung beschw\u00f6rt, zu annullieren und die Karten zu zerst\u00f6ren."
    },
    "es": {
      "name": "Opresi\u00f3n Real",
      "effect": "Cualquier jugador puede Pagar 800 Life Points para negar la Invocaci\u00f3n Especial de uno o m\u00e1s monstruos y/o el efecto de una carta que Invoca a uno o m\u00e1s monstruos de Modo Especial, y destruir esas cartas."
    },
    "fr": {
      "name": "Oppression Royale",
      "effect": "Chaque joueur peut payer 800 Life Points pour annuler l'Invocation Sp\u00e9ciale d'un ou plusieurs monstres, et/ou un effet qui permet d'Invoquer Sp\u00e9cialement un ou plusieurs monstres, et d\u00e9truire ces cartes."
    },
    "it": {
      "name": "Oppressione Reale",
      "effect": "Paga 800 Life Points. Annulla l'Evocazione Speciale di un Mostro e\\o l'effetto che include l'Evocazione Speciale di un Mostro e distruggi quella carta. Anche il tuo avversario pu\u00f2 utilizzare questo effetto."
    },
    "pt": {
      "name": "Opress\u00e3o Real",
      "effect": "Pague 800 Life Points. Anule a Invoca\u00e7\u00e3o-Especial de um monstro(s) e o efeito de um card que Invoca por Invoca\u00e7\u00e3o-Especial um monstro(s) e destrua-o. Tanto voc\u00ea como o seu advers\u00e1rio podem usar este efeito."
    },
