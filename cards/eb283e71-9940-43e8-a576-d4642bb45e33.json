    "en": {
      "name": "Battlewasp - Wind",
      "effect": "Up to twice per turn, if a \"Battlewasp\" monster(s) is Normal or Special Summoned to your field (except during the Damage Step): You can target 1 of them; add 1 \"Battlewasp\" monster with less ATK from your Deck to your hand. Once per turn: You can target 1 Insect monster you control that has a Level; if you use it as Synchro Material this turn, you can treat it as a Tuner. You can only activate 1 \"Battlewasp - Wind\" per turn.",
      "official": false
    },
